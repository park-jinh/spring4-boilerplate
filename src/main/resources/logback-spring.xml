<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
      [SpringProperty 주입]
      application.yml에서 설정한 값을 로직 내부에서 변수로 사용합니다.
    -->
    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="./logs"/>
    <springProperty scope="context" name="LOG_FILE_NAME" source="spring.application.name" defaultValue="application"/>
    <springProperty scope="context" name="MAX_HISTORY" source="logging.logback.rollingpolicy.max-history" defaultValue="7"/>
    <springProperty scope="context" name="MAX_FILE_SIZE" source="logging.logback.rollingpolicy.max-file-size" defaultValue="10MB"/>

    <!-- 컬러 출력 패턴 (Console 전용) -->
    <property name="CONSOLE_LOG_PATTERN" value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n%wEx"/>

    <!-- 파일 출력 패턴 (File 전용) -->
    <property name="FILE_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p ${PID:- } --- [%t] %-40.40logger{39} : %m%n%wEx"/>

    <!-- 1. 콘솔(Console) 앱엔더 설정 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 2. 파일(File) 롤링 앱엔더 설정 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}.log</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>

        <!-- 사이즈 및 시간 기반 롤링 정책 (SizeAndTimeBasedRollingPolicy) -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 날짜 및 인덱스별 파일명 패턴 -->
            <fileNamePattern>${LOG_PATH}/archived/${LOG_FILE_NAME}-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 파일 한 개당 최대 용량 -->
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <!-- 로그 보관 주기 (일 단위) -->
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <!-- 전체 로그 파일 총 용량 제한 -->
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!--
      [프로필별 설정 제어]
      local 프로필: 콘솔 로그만 출력 (개발 효율성 중심)
    -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.jinh.boilerplate" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <!--
      dev 및 prod 프로필: 콘솔과 파일 모두 기록 (안정성 및 추적성 중심)
    -->
    <springProfile name="dev, prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.jinh.boilerplate" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>
    </springProfile>

    <!-- 프레임워크 로그 수준 개별 설정 -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/> <!-- SQL 출력 필요 시 -->

</configuration>